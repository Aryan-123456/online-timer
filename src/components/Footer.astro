---

const year = new Date().getFullYear();

const tools = [
  { href: '/clock', label: 'World Clock' },
  { href: '/countdown', label: 'Countdown Timer' },
  { href: '/stopwatch', label: 'Online Stopwatch' },
  { href: '/pomodoro', label: 'Pomodoro Timer' },
];

const info = [
  { href: '/about', label: 'About Us' },
  { href: '/contact', label: 'Contact Us' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms & Conditions' },
];
---

<footer class="border-t border-hairline bg-canvas">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-8">
      <div class="col-span-2 sm:col-span-1">
        <a href="/" class="flex items-center gap-2 no-underline mb-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 focus-visible:ring-offset-2 rounded-sm touch-manipulation">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <span class="font-semibold text-sm text-ink">Online Timer</span>
        </a>
        <p class="text-mute text-xs leading-relaxed">
          A clean, fast, and minimal online timer toolkit.<br/>
          Free to use — no ads, no clutter.
        </p>
      </div>
      <div>
        <p class="text-xs font-medium text-mute uppercase tracking-wider mb-3 font-mono">Tools</p>
        {tools.map(link => (
          <a href={link.href} class="block text-sm text-body hover:text-ink transition-colors no-underline py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 rounded-sm touch-manipulation">{link.label}</a>
        ))}
      </div>
      <div>
        <p class="text-xs font-medium text-mute uppercase tracking-wider mb-3 font-mono">Info</p>
        {info.map(link => (
          <a href={link.href} class="block text-sm text-body hover:text-ink transition-colors no-underline py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 rounded-sm touch-manipulation">{link.label}</a>
        ))}
      </div>
      <div>
        <p class="text-xs font-medium text-mute uppercase tracking-wider mb-3 font-mono">Legal</p>
        <p class="text-xs text-mute">&copy; {year} onlinetimer.in</p>
      </div>
    </div>
  </div>
</footer>
