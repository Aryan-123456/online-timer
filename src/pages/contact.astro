---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Us — Online Timer",
  "description": "Get in touch with the Online Timer team.",
  "url": "https://onlinetimer.online/contact",
  "mainEntity": {
    "@type": "Organization",
    "name": "Online Timer",
    "url": "https://onlinetimer.online/",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "hello@onlinetimer.online",
      "contactType": "customer service"
    }
  }
};
---

<Layout title="Contact Us — Online Timer" description="Get in touch with the Online Timer team. Send us your feedback, questions, or suggestions. We'd love to hear from you." canonical="https://onlinetimer.online/contact" keywords="contact online timer, feedback, support, email online timer" breadcrumbs={[{ name: "Home", url: "/" }, { name: "Contact Us", url: "/contact" }]}>
  <Nav currentPath="/contact" />

  <main class="max-w-3xl mx-auto px-5 sm:px-6 pb-16 sm:pb-24">
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-[clamp(1.35rem,5vw,2.5rem)] font-semibold leading-tight tracking-[-0.8px] sm:tracking-[-1.28px] text-ink mb-2 sm:mb-3">Contact Us</h1>
      <p class="text-body text-sm sm:text-base max-w-lg mx-auto">
        Have feedback, questions, or suggestions? We'd love to hear from you.
      </p>
    </div>

    <div class="bg-canvas rounded-xl border border-hairline p-6 sm:p-10">
      <form action="mailto:hello@onlinetimer.online" method="get" enctype="text/plain">
        <div class="mb-4">
          <label for="name" class="block text-sm font-medium text-ink mb-2">Name</label>
          <input type="text" id="name" name="subject" class="w-full px-4 py-2.5 rounded-lg border border-hairline bg-canvas-soft text-ink text-sm focus:outline-none focus:ring-2 focus:ring-ink/40 focus:border-ink transition-colors" placeholder="Your name" required />
        </div>
        <div class="mb-4">
          <label for="email" class="block text-sm font-medium text-ink mb-2">Email</label>
          <input type="email" id="email" name="email" class="w-full px-4 py-2.5 rounded-lg border border-hairline bg-canvas-soft text-ink text-sm focus:outline-none focus:ring-2 focus:ring-ink/40 focus:border-ink transition-colors" placeholder="you@example.com" required />
        </div>
        <div class="mb-4">
          <label for="message" class="block text-sm font-medium text-ink mb-2">Message</label>
          <textarea id="message" name="body" rows="5" class="w-full px-4 py-2.5 rounded-lg border border-hairline bg-canvas-soft text-ink text-sm focus:outline-none focus:ring-2 focus:ring-ink/40 focus:border-ink transition-colors resize-y" placeholder="Your message..." required></textarea>
        </div>
        <button type="submit" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-5 sm:px-6 py-3.5 sm:py-2.5 rounded-pill bg-ink text-on-primary text-base sm:text-sm font-medium cursor-pointer hover:opacity-90 transition-opacity border-none touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 focus-visible:ring-offset-2 min-h-[48px]">Send Message</button>
      </form>
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline>
  document.head.insertAdjacentHTML('beforeend', `<script type="application/ld+json">${JSON.stringify(structuredData)}<\/script>`);
</script>
