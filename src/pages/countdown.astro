---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Countdown Timer — Online Timer" description="Set precise countdowns and share them with anyone via a unique link.">
  <Nav currentPath="/countdown" />

  <main class="max-w-2xl mx-auto px-5 sm:px-6 py-8 sm:py-12">
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-[clamp(1.35rem,5vw,2.5rem)] font-semibold leading-tight tracking-[-0.8px] sm:tracking-[-1.28px] text-ink mb-2 sm:mb-3">
        Countdown Timer
      </h1>
      <p class="text-body text-sm sm:text-base max-w-lg mx-auto">
        Tap the timer to set a time. Share any countdown with <code class="bg-canvas-soft-2 px-1.5 py-0.5 rounded text-xs font-mono">?t=3600</code>.
      </p>
    </div>

    <div class="bg-canvas rounded-lg border border-hairline p-6 sm:p-10 text-center">
      <div class="mb-6">
        <p id="countdown-display" class="text-[clamp(2.5rem,12vw,5rem)] font-semibold font-mono text-ink tracking-tight leading-none cursor-pointer">00:00:00</p>
      </div>

      <svg class="w-20 h-20 sm:w-24 sm:h-24 mx-auto mb-6 -rotate-90" viewBox="0 0 100 100" aria-hidden="true">
        <circle cx="50" cy="50" r="45" fill="none" stroke="var(--color-hairline)" stroke-width="6" />
        <circle id="countdown-progress" cx="50" cy="50" r="45" fill="none" stroke="var(--color-ink)" stroke-width="6" stroke-linecap="round"
          stroke-dasharray="283" stroke-dashoffset="283" class="transition-[stroke-dashoffset] duration-100 ease-linear" />
      </svg>

      <div class="flex items-center justify-center gap-3 flex-wrap">
        <button id="countdown-start" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-5 sm:px-6 py-3.5 sm:py-2.5 rounded-pill bg-ink text-on-primary text-base sm:text-sm font-medium cursor-pointer hover:opacity-90 transition-opacity border-none touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 focus-visible:ring-offset-2 min-h-[48px]">Start</button>
        <button id="countdown-reset" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-5 sm:px-6 py-3.5 sm:py-2.5 rounded-pill bg-canvas text-ink text-base sm:text-sm font-medium cursor-pointer border border-hairline hover:bg-canvas-soft-2 transition-colors touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 min-h-[48px]">Reset</button>
        <button id="countdown-share" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-5 sm:px-6 py-3.5 sm:py-2.5 rounded-pill bg-canvas text-ink text-base sm:text-sm font-medium cursor-pointer border border-hairline hover:bg-canvas-soft-2 transition-colors touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 min-h-[48px]">Share</button>
        <button id="countdown-fullscreen" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-4 py-3.5 sm:py-2.5 rounded-pill bg-canvas text-ink text-sm font-medium cursor-pointer border border-hairline hover:bg-canvas-soft-2 transition-colors touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 min-h-[48px] flex items-center justify-center" aria-label="Enter fullscreen">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/></svg>
        </button>
      </div>
      <p id="share-url" class="hidden mt-4 text-sm text-body font-mono break-all"></p>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { initCountdown } from '../lib/countdown.js';
  initCountdown();
</script>
