---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Stopwatch — Online Timer" description="Free online stopwatch with lap recording. Precision stop watch accurate to 10 milliseconds. Track elapsed time with start, stop, and lap controls." canonical="https://onlinetimer.online/stopwatch" keywords="stopwatch, stop watch, online stopwatch, timer, online timer, stopwatch with lap" breadcrumbs={[{ name: "Home", url: "/" }, { name: "Stopwatch", url: "/stopwatch" }]}>
  <Nav currentPath="/stopwatch" />

  <main class="max-w-2xl mx-auto px-5 sm:px-6 py-8 sm:py-12">
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-[clamp(1.35rem,5vw,2.5rem)] font-semibold leading-tight tracking-[-0.8px] sm:tracking-[-1.28px] text-ink mb-2 sm:mb-3">
        Stopwatch — Free Online Stopwatch with Lap Recording
      </h1>
      <p class="text-body text-sm sm:text-base max-w-lg mx-auto">
        Precision <strong>stopwatch</strong> (also known as a <strong>stop watch</strong>) with lap recording. Accurate to 10 milliseconds.
      </p>
    </div>

    <div class="p-6 sm:p-10">
      <div class="text-center mb-8">
        <p id="sw-display" class="text-[clamp(2.5rem,12vw,5rem)] font-semibold font-mono text-ink tracking-tight leading-none cursor-pointer">00:00.00</p>
      </div>

      <div class="flex items-center justify-center gap-3 flex-wrap mb-8">
        <button id="sw-start" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-5 sm:px-6 py-3.5 sm:py-2.5 rounded-pill bg-ink text-on-primary text-base sm:text-sm font-medium cursor-pointer hover:opacity-90 transition-opacity border-none touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 focus-visible:ring-offset-2 min-h-[48px]">Start</button>
        <button id="sw-lap" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-5 sm:px-6 py-3.5 sm:py-2.5 rounded-pill bg-canvas text-ink text-base sm:text-sm font-medium cursor-pointer border border-hairline hover:bg-canvas-soft-2 transition-colors disabled:opacity-40 disabled:cursor-not-allowed touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 min-h-[48px]" disabled>Lap</button>
        <button id="sw-reset" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-5 sm:px-6 py-3.5 sm:py-2.5 rounded-pill bg-canvas text-ink text-base sm:text-sm font-medium cursor-pointer border border-hairline hover:bg-canvas-soft-2 transition-colors touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 min-h-[48px]">Reset</button>
        <button id="sw-fullscreen" class="grow sm:grow-0 shrink-0 whitespace-nowrap px-4 py-3.5 sm:py-2.5 rounded-pill bg-canvas text-ink text-sm font-medium cursor-pointer border border-hairline hover:bg-canvas-soft-2 transition-colors touch-manipulation focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 min-h-[48px] flex items-center justify-center" aria-label="Enter fullscreen">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/></svg>
        </button>
      </div>

      <div id="sw-laps" class="max-h-48 sm:max-h-64 overflow-y-auto border-t border-hairline">
        <div class="flex items-center justify-between py-2.5 sm:py-2 px-3 sm:px-4 text-xs font-mono text-mute uppercase tracking-wider">
          <span>Lap</span>
          <span>Lap Time</span>
          <span>Total Time</span>
        </div>
      </div>
    </div>
  </main>

  <section class="max-w-4xl mx-auto px-5 sm:px-6 pb-8 sm:pb-12 text-center">
    <p class="text-mute text-xs font-mono uppercase tracking-wider mb-3">More Tools</p>
    <div class="flex flex-wrap justify-center gap-2 sm:gap-3">
      <a href="/countdown" class="px-4 py-2 rounded-full border border-hairline bg-canvas text-ink text-sm font-medium no-underline hover:bg-ink hover:text-on-primary hover:border-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40">Countdown Timer</a>
      <a href="/pomodoro" class="px-4 py-2 rounded-full border border-hairline bg-canvas text-ink text-sm font-medium no-underline hover:bg-ink hover:text-on-primary hover:border-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40">Pomodoro Timer</a>
      <a href="/clock" class="px-4 py-2 rounded-full border border-hairline bg-canvas text-ink text-sm font-medium no-underline hover:bg-ink hover:text-on-primary hover:border-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40">World Clock</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  #sw-laps::-webkit-scrollbar { width: 4px; }
  #sw-laps::-webkit-scrollbar-track { background: transparent; }
  #sw-laps::-webkit-scrollbar-thumb { background: var(--color-hairline); border-radius: 4px; }
</style>

<script>
  import { initStopwatch } from '../lib/stopwatch.js';
  initStopwatch();
</script>
